#!/bin/bash
set -euo pipefail
cmd="$1"; sub="${2:-}"; shift; shift || true
if [[ "$cmd" == "pr" && "$sub" == "view" ]]; then
  jq_expr=""
  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--jq" ]]; then jq_expr="$2"; break; fi
    shift
  done
  case "$jq_expr" in
    ".state") echo "${GH_PR_STATE:-OPEN}" ;;
    ".isDraft") echo "${GH_PR_DRAFT:-false}" ;;
    ".autoMergeRequest != null") echo "${GH_PR_AUTO_MERGE:-false}" ;;
    ".headRefOid") echo "${GH_PR_HEAD_OID:-head-sha}" ;;
    *) exit 1 ;;
  esac
  exit 0
fi
if [[ "$cmd" == "api" ]]; then
  jq_expr=""
  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--jq" ]]; then jq_expr="$2"; break; fi
    shift
  done
  case "$jq_expr" in
    ".allow_squash_merge") echo "${GH_ALLOW_SQUASH:-true}" ;;
    ".allow_rebase_merge") echo "${GH_ALLOW_REBASE:-false}" ;;
    ".allow_merge_commit") echo "${GH_ALLOW_MERGE:-false}" ;;
    *) exit 1 ;;
  esac
  exit 0
fi
if [[ "$cmd" == "pr" && "$sub" == "merge" ]]; then
  echo "pr merge $*" >> "${GH_LOG_PATH}"
  [[ "$*" == *"--squash"* ]]
  exit $?
fi
exit 1
